---
import Layout from '../layouts/Layout.astro'
import { FAQ_ITEMS } from '../components/Landing.jsx'
import AdSenseAd from '../components/AdSenseAd'
import { getAdsenseConfig } from '../lib/server/env'
import LandingCourses from '../components/LandingCourses.jsx'

const { client: adsenseClient, enabledByEnv: adsEnabledByEnv } = getAdsenseConfig()
---
<Layout
  title="Hacer y crear cuestionarios online"
  description="Busca, resuelve y crea cuestionarios tipo test online. Una herramienta rápida para estudiar por curso, asignatura y tema sin distracciones."
  structuredData={[
    {
      '@context': 'https://schema.org',
      '@type': 'WebApplication',
      name: 'Cuestionarios online',
      applicationCategory: 'EducationalApplication',
      operatingSystem: 'Web',
      inLanguage: 'es',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'EUR' }
    },
    {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: FAQ_ITEMS.map((item) => ({
        '@type': 'Question',
        name: item.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: item.answer
        }
      }))
    }
  ]}
>
  <div class="page-wrap landing">
    <section class="landing-search" id="catalog-section" aria-labelledby="catalog-heading">
      <header class="landing-header landing-header--centered">
        <p class="section-kicker">Cuestionarios hechos por alumnos</p>
        <h1 id="catalog-heading">Busca un cuestionario</h1>
        <p class="hero-subtitle">Encuentra tests por curso, asignatura o tema. Entra, responde y revisa resultados sin distracciones.</p>
        <div class="study-terminal" aria-label="Flujo de estudio">
          <span>&gt; selecciona asignatura</span>
          <span>&gt; responde preguntas</span>
          <span>&gt; revisa resultados</span>
        </div>
      </header>
      <LandingCourses client:visible showSearch={true} showViewAll={true} compact={true} searchMode="all" emptyUntilSearch={true} syncUrl={true} />
    </section>

    <AdSenseAd client:visible slot="4731901740" className="ad-slot ad-slot--wide" clientId={adsenseClient} enabledByEnv={adsEnabledByEnv} />

    <section class="landing-catalog" aria-labelledby="create-heading">
      <div class="section-heading">
        <p class="section-kicker">Crear</p>
        <h2 id="create-heading">Crea cuestionarios para estudiar</h2>
        <p>Si no encuentras lo que necesitas, puedes crear un cuestionario desde tus apuntes, un PDF o un JSON revisado.</p>
      </div>
      <nav class="user-actions" aria-label="Crear o explorar">
        <a href="/crear" class="btn-primary">Crear cuestionario</a>
        <a href="/cursos" class="btn-secondary">Ver todos los cursos</a>
      </nav>
    </section>

    <section class="landing-info" aria-labelledby="project-heading">
      <div class="section-heading">
        <p class="section-kicker">Para estudiar mejor</p>
        <h2 id="project-heading">Pensada para hacer cuestionarios, no para navegar menús</h2>
      </div>
      <div class="content-grid">
        <article>
          <h3>Buscar</h3>
          <p>Encuentra cuestionarios por curso, asignatura o tema sin revisar listas enormes.</p>
        </article>
        <article>
          <h3>Resolver</h3>
          <p>Al abrir un cuestionario ves pregunta, opciones, progreso y resultado. Nada más.</p>
        </article>
        <article>
          <h3>Crear</h3>
          <p>Sube apuntes o pega JSON para preparar tests propios y guardarlos para estudiar.</p>
        </article>
      </div>
    </section>

    <section class="landing-steps" aria-labelledby="how-heading">
      <div class="section-heading">
        <p class="section-kicker">Cómo funciona</p>
        <h2 id="how-heading">Empieza en tres pasos</h2>
      </div>
      <ol class="steps-list">
        <li><strong>Busca.</strong> Escribe curso, asignatura o tema.</li>
        <li><strong>Entra.</strong> Abre el curso o unidad que necesitas practicar.</li>
        <li><strong>Resuelve o crea.</strong> Contesta el test o genera uno nuevo desde tus apuntes.</li>
      </ol>
    </section>

    <section class="landing-faq" aria-labelledby="faq-heading">
      <div class="section-heading">
        <p class="section-kicker">Preguntas frecuentes</p>
        <h2 id="faq-heading">FAQ sobre los cuestionarios</h2>
      </div>
      <div class="faq-list">
        {FAQ_ITEMS.map((item) => (
          <details class="faq-item">
            <summary>{item.question}</summary>
            <p>{item.answer}</p>
          </details>
        ))}
      </div>
    </section>
  </div>
</Layout>
