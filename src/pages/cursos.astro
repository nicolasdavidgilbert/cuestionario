---
import Layout from '../layouts/Layout.astro'
import LandingCourses from '../components/LandingCourses.jsx'
import AdSenseAd from '../components/AdSenseAd'
import { getAdsenseConfig } from '../lib/server/env'

const { client: adsenseClient, enabledByEnv: adsEnabledByEnv } = getAdsenseConfig()
---
<Layout
  title="Cursos con cuestionarios"
  description="Explora los cursos disponibles y accede a cuestionarios tipo test organizados por asignatura y unidad."
>
  <div class="page-wrap courses-page">
    <a href="/" class="quiz-back">← Volver al inicio</a>

    <header class="home-header courses-header">
      <p class="section-kicker">Catálogo</p>
      <h1>Cursos disponibles</h1>
      <p>Busca entre todos los cursos. Esta página está pensada para catálogos grandes, con listado compacto y carga progresiva.</p>
    </header>

    <section class="courses-catalog-shell" aria-label="Lista de cursos disponibles">
      <LandingCourses client:idle showSearch={true} compact={true} />
    </section>

    <AdSenseAd client:visible slot={import.meta.env.PUBLIC_ADSENSE_SLOT || "4731901740"}  className="ad-slot ad-slot--wide" clientId={adsenseClient} enabledByEnv={adsEnabledByEnv} />
  </div>
</Layout>
