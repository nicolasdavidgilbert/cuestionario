---
import Layout from '../layouts/Layout.astro'
import { getContactEmail } from '../lib/server/env'

const contactEmail = getContactEmail()
---

<Layout title="Contacto | Cuestionarios">
  <div class="page-wrap legal-page">
    <a href="/" class="quiz-back">← Volver</a>

    <header class="home-header">
      <h1>Contacto</h1>
      <p>Escríbenos para dudas sobre la app, privacidad o funcionamiento.</p>
    </header>

    <section class="legal-card">
      <h2>Email de contacto</h2>
      <p>
        Puedes escribir a <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.
      </p>
    </section>

    <section class="legal-card">
      <h2>Formulario</h2>
      <p>
        Todavía no hay backend de contacto integrado en esta app, así que por ahora usamos correo directo.
      </p>
    </section>
  </div>
</Layout>
