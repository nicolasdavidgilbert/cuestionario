---
import Layout from '../layouts/Layout.astro'
import Catalog from '../components/Catalog.jsx'
import { getAdsenseConfig } from '../lib/server/env'

const { grado } = Astro.params
const { client: adsenseClient, enabledByEnv: adsEnabledByEnv } = getAdsenseConfig()
---
<Layout title={grado ? `${grado} - Cuestionarios` : 'Cuestionarios'}>
  <Catalog grado={grado} adsenseClient={adsenseClient} enabledByEnv={adsEnabledByEnv} client:load />
</Layout>
