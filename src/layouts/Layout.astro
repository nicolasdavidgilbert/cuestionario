---
import AdSenseManager from '../components/AdSenseManager'
import CookieConsentBanner from '../components/CookieConsentBanner'
import { getAdsenseConfig } from '../lib/server/env'
interface Props {
  title?: string
}
const { title = 'Cuestionarios' } = Astro.props
const { client: adsenseClient, enabledByEnv: adsEnabledByEnv } = getAdsenseConfig()
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://cuestionario.online').toString()
const currentYear = new Date().getFullYear()
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
  </head>
  <body>
    <div id="root">
      <main class="site-shell">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <p class="site-footer__brand">Cuestionarios</p>
          <nav class="site-footer__links" aria-label="Enlaces legales">
            <a href="/privacy-policy">Política de privacidad</a>
            <a href="/terms">Términos</a>
            <a href="/contact">Contacto</a>
            <button type="button" class="site-footer__cookie-button" data-open-cookie-consent>
              Configurar cookies
            </button>
          </nav>
          <p class="site-footer__meta">
            © {currentYear} cuestionario.online. Preparado para uso con Google AdSense y consentimiento en UE.
          </p>
        </div>
      </footer>
    </div>
    <AdSenseManager client:load clientId={adsenseClient} enabledByEnv={adsEnabledByEnv} />
    <CookieConsentBanner client:load adsEnabledByEnv={adsEnabledByEnv} />
    <script is:inline>
      document.addEventListener('click', function (event) {
        const target = event.target instanceof Element ? event.target.closest('[data-open-cookie-consent]') : null;
        if (!target) return;
        window.dispatchEvent(new Event('cookie-consent:open'));
      });
    </script>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
