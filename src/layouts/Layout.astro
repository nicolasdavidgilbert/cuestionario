---
import AdSenseManager from '../components/AdSenseManager'
import CookieConsentBanner from '../components/CookieConsentBanner'
import { getAdsenseConfig } from '../lib/server/env'
import { canServeAdsOnPage } from '../lib/ads'

interface Props {
  title?: string
  description?: string
  image?: string
  robots?: 'index, follow' | 'noindex, nofollow'
  structuredData?: Record<string, unknown> | Record<string, unknown>[]
}

const SITE_NAME = 'Cuestionarios'
const DEFAULT_DESCRIPTION = 'Practica cuestionarios tipo test por curso, asignatura y unidad. Estudia con una interfaz clara, rápida y centrada en responder.'

const {
  title = SITE_NAME,
  description = DEFAULT_DESCRIPTION,
  image = '/assets/favicon.png',
  robots = 'index, follow',
  structuredData
} = Astro.props

const { client: adsenseClient, enabledByEnv: adsEnabledByEnv } = getAdsenseConfig()
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://cuestionario.online').toString()
const absoluteImageUrl = new URL(image, Astro.site ?? 'https://cuestionario.online').toString()
const currentYear = new Date().getFullYear()
const adsOnThisPage = canServeAdsOnPage(Astro.url.pathname, adsEnabledByEnv, adsenseClient)
const pageTitle = title === SITE_NAME ? SITE_NAME : `${title} | ${SITE_NAME}`
const baseStructuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: SITE_NAME,
  url: new URL('/', Astro.site ?? 'https://cuestionario.online').toString(),
  description: DEFAULT_DESCRIPTION,
  inLanguage: 'es'
}
const jsonLd = structuredData
  ? Array.isArray(structuredData)
    ? [baseStructuredData, ...structuredData]
    : [baseStructuredData, structuredData]
  : [baseStructuredData]
---
<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={`${robots}, max-snippet:160, max-image-preview:large`} />
    <meta name="theme-color" content="#f8fafc" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={absoluteImageUrl} />
    <meta property="og:locale" content="es_ES" />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteImageUrl} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <div id="root">
      <header class="site-header">
        <div class="site-header__inner">
          <a href="/" class="site-brand" aria-label="Ir al inicio">
            <span class="site-brand__mark" aria-hidden="true">?</span>
            <span>Cuestionarios</span>
          </a>
          <nav class="site-nav" aria-label="Navegación principal">
            <a href="/cursos">Cursos</a>
            <a href="/crear">Crear</a>
            <a href="/mis-cuestionarios">Mis cuestionarios</a>
          </nav>
        </div>
      </header>
      <main class="site-shell">
        <slot />
      </main>
      <footer class="site-footer">
        <div class="site-footer__inner">
          <p class="site-footer__brand">Cuestionarios</p>
          <nav class="site-footer__links" aria-label="Enlaces legales">
            <a href="/privacy-policy">Política de privacidad</a>
            <a href="/terms">Términos</a>
            <a href="/contact">Contacto</a>
          </nav>
          <p class="site-footer__meta">
            © {currentYear} cuestionario.online. Preparado para uso con Google AdSense y consentimiento de anuncios en UE.
          </p>
        </div>
      </footer>
    </div>
    {adsOnThisPage && <AdSenseManager client:idle clientId={adsenseClient} enabledByEnv={adsEnabledByEnv} />}
    <CookieConsentBanner client:idle enabled={adsOnThisPage} />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
